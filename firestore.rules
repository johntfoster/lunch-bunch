rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is a group manager (email in managers array)
    function isManager(groupId) {
      return request.auth.token.email in get(/databases/$(database)/documents/groups/$(groupId)).data.managers;
    }

    // Helper: check if user is a group member (member doc exists)
    function isMember(groupId) {
      return exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    // Helper: user is manager or member of the group
    function isGroupUser(groupId) {
      return isManager(groupId) || isMember(groupId);
    }

    // Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Groups: readable by any authenticated user (needed for group discovery/switching)
    // Write operations restricted to managers
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isManager(groupId);

      // Members subcollection: readable by any authenticated user (needed for membership checks)
      // Write restricted: create open (for joining), delete by self or manager
      match /members/{memberId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (request.auth.uid == memberId || isManager(groupId));
      }

      // Pending members: only managers can read/delete, anyone can request to join
      match /pendingMembers/{memberId} {
        allow read: if request.auth != null && isManager(groupId);
        allow create: if request.auth != null;
        allow delete: if request.auth != null && isManager(groupId);
      }

      // Votes: readable by any authenticated user, writable by members only
      match /votes/{dateId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && isGroupUser(groupId);

        // Ballots: one vote per user per day, must be a member
        match /ballots/{userId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null && request.auth.uid == userId && isMember(groupId);
          allow update: if request.auth != null && request.auth.uid == userId && isMember(groupId);
          allow delete: if false;
        }

        // Daily extras: readable by anyone, writable by members
        match /extras/{extraId} {
          allow read: if request.auth != null;
          allow write: if request.auth != null && isGroupUser(groupId);
        }
      }

      // History: readable by any authenticated user, writable by members
      match /history/{dateId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && isGroupUser(groupId);
        allow update, delete: if false;
      }

      // Notification log: deny client access (only Cloud Functions)
      match /notificationLog/{dateId} {
        allow read, write: if false;
      }
    }
  }
}
